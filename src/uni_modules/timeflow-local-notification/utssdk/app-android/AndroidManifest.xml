<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  package="io.dcloud.uni_modules.timeflowLocalNotification">
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

  <application>
    <receiver
      android:name="uts.sdk.modules.timeflowLocalNotification.ReminderAlarmReceiver"
      android:enabled="true"
      android:exported="false" />

    <receiver
      android:name="uts.sdk.modules.timeflowLocalNotification.ReminderRestoreReceiver"
      android:enabled="true"
      android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="android.intent.action.TIME_SET" />
        <action android:name="android.intent.action.TIMEZONE_CHANGED" />
        <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
      </intent-filter>
    </receiver>
  </application>
</manifest>
